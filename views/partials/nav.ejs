<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand">🎓 Campus Events</a>
    <nav class="nav-links">
      <a href="/">Events</a>
      <% if (currentUser) { %>
        <a href="/events/new">+ New Event</a>
        <span class="nav-user">
          Hi, <%= currentUser.name %><% if (currentUser.role === 'admin') { %> <span class="tag">admin</span><% } %>
        </span>
        <form action="/logout" method="POST" class="inline">
          <button type="submit" class="link-btn">Logout</button>
        </form>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register" class="btn btn-small">Register</a>
      <% } %>
    </nav>
  </div>
</header>
